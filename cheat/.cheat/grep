grep pattern file # Search a file for a pattern

grep -w <word> file # find only word like 'the' and not 'there'

# Search a file for multiple pattern
grep 'pattern1\|pattern2' fileName_or_filePath     # multiple pattern
grep -E 'pattern1|pattern2' fileName_or_filePath   # multiple pattern
egrep 'pattern1|pattern2' fileName_or_filePath     # deprecated
grep -e pattern1 -e pattern2 fileName_or_filePath  # multiple pattern

grep -c 'pattern1\|pattern2' fileName_or_filePath  # search and count of multiple matches in a file

grep -in pattern file     # Case insensitive search (with line numbers)

grep -R pattern folder    # Recursively grep for string <pattern> in folder:

grep -f pattern_file file # Read search patterns from a file (one per line)

grep -v pattern file      # Find lines NOT containing pattern

grep -A <number_of_lines> pattern file # print lines after match

grep -B <number_of_lines> pattern file # print lines before match

# You can grep with regular expressions
grep "^00" file  # Regex Match lines starting with 00
grep -E "[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}" file  #Find IP add

# Find all files which match {pattern} in {directory}
# This will show: "file:line my research"
grep -rnw 'directory' -e "pattern"

# Exclude grep from your grepped output of ps.
# Add [] to the first letter. Ex: sshd -> [s]shd
ps aux | grep '[h]ttpd'

ps aux | grep -E --color 'bash|$' # Colour in red {bash} and keep all other lines

cat <file> | grep -v -e '^$'      # grep and remove empty lines

