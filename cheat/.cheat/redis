## HASHES
# Sets the specified fields to their respective values in the hash stored at key.Time Complexity: O(N)
HSET h_employee_profile:101 name "Nicol" age 33
(integer) 2


HSET key field value [field value ...]
HSET h_employee_profile:101 name "Nicol" age 33
(integer) 2


# Returns the value associated with field in the hash stored at key.Time Complexity: O(1)
HGET key field
HGET h_employee_profile:101 name
"Nicol"


# Returns all fields and values of the hash stored at key.Time Complexity: O(N)
HGETALL key
HGETALL h_employee_profile:101
1) "name" 2) "Nicol" 3) "age" 4) "33"

# Returns the values associated with the specified fields in the hash stored at key.Time Complexity: O(N)
HMGET key field1 [field2]
HMGET h_employee_profile:101 name age
1) "Nicol" 2) "33"

## Sets

# Appends the specified stream entry to the stream at the specified key. Time Complexity: O(1) when adding a new entry.
XADD key field value [field value ...]
XADD myStream * sensorId "1234" temperature "19.8"
1518951480106-0


# Read data from one or multiple streams, only returning entries with an ID greater than the last received ID reported by the caller.
XREAD [COUNT count] [BLOCK milliseconds] STREAMS key [key ...] ID [ID ...]
XREAD COUNT 2 STREAMS myStream 0
1) 1) "myStream" 2) 1) 1) "1518951480106-0" 2) 1) "sensorId" 2) "1234" 3) "temperature" 4) "19.8"


# Returns the entries matching a range of IDs in a stream. Time Complexity: O(N) with N being the number of elements being returned. If N is constant (e.g. always asking for the first 10 elements with COUNT), you can consider it O(1).
XRANGE key start end [COUNT count]
XRANGE myStream 1518951480106-0 1518951480106-0
1) 1) 1) "1518951480106-0" 2) 1) "sensorId" 2) "1234" 3) "temperature" 4) "19.8"


# Returns the number of entries of a stream. Time Complexity: O(1)
XLEN myStream
(integer) 1


# Removes the specified entries from a stream. Time Complexity: O(1) for each single item to delete in the stream
XDEL key ID [ID ...]
XDEL myStream 1518951480106-0
(integer) 1


# Trims the stream to a different length. Time Complexity: O(N), with N being the number of evicted entries. Constant times are very small however, since entries are organized in macro nodes containing multiple entries that can be released with a single deallocation.
XTRIM key MAXLEN [~] count
XTRIM myStream MAXLEN 0
(integer) 0

## Sorted sets

# Adds all the specified members with the specified scores to the sorted set stored at key. Time Complexity: O(log(N))
ZADD key score member [score member ...]
ZADD myZSet 1 "one" 2 "two"
(integer) 2


# Returns the specified range of elements in the sorted set stored at key.Time Complexity: O(log(N)+M) where M is the number of elements returned
ZRANGE key start stop [WITHSCORES]
ZRANGE myZSet 0 -1
1) "one" 2)"two"

## Lists

# Inserts the specified values at the head of the list stored at key. Time Complexity: O(N)
LPUSH key value [value ...]
LPUSH myList "World"
(integer) 1


# Inserts the specified values at the tail of the list stored at key.Time Complexity: O(N)
RPUSH key value [value ...]
RPUSH myList "Hello"
(integer) 2


# Returns the specified elements of the list stored at key.Time Complexity: O(S+N) where S is the distance of start and N is the number of elements in the specified range.
LRANGE key start stop
LRANGE myList 0 -1
1) "World" 2) "Hello"


# Returns the length of the list stored at key.Time Complexity: O(1)
LLEN key
LLEN myList
(integer) 2


# Removes and returns the first element of the list stored at key.Time Complexity: O(N)
LPOP key [count]
LPOP myList
"World"

# Removes and returns the last element of the list stored at key.Time Complexity: O(N)
RPOP key [count]
RPOP myList
"Hello"

