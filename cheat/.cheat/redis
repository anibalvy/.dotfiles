# Syntax
redis-cli -u redis://host:port
redis-cli -u redis://username:password@host:port

# Examples
redis-cli
redis-cli -u redis://localhost:6379
redis-cli -u redis://myuser:mypassword@localhost:6379

# If you run Redis through Docker
docker exec -it <container-id-or-name> redis-cli

# To set redis-cli preferences:
:set hints    # enable online hints
:set nohints  # disable online hints


# Time Complexity: O(1)
SET myKey "Hello"
"OK"

# Time Complexity: O(1)
GET myKey
"Hello"

#  values of all specified keys. Time Complexity: O(N)
MGET myKey nonExistentKey
1) "Hello" 2) (nil)

# increment by 1. Time Complexity: O(1)
INCR myCounter
(integer) 1

# all keys matching pattern.Time Complexity: O(N)
KEYS my*
1) "myKey" 2) "myCounter"

# if one or more keys exist.Time Complexity: O(N)
EXISTS myKey
(integer) 1

# set timeout in seconds. Set a timeout on a key.After the timeout has expired, the key will automatically be deleted.Time Complexity:O(1)
EXPIRE myKey 120
(integer) 1

# remaining time to live of a key that has a timeout.Time Complexity: O(1)
TTL myKey
(integer) 113

# Removes the expiration from a key.Time Complexity:O(1)
PERSIST myKey
(integer) 1

# Iterates the set of keys in the currently selected Redis database.Time Complexity: O(1) for every call
SCAN 0 MATCH my* COUNT 2
1) "3" 2) 1) "myCounter" 2) "myKey"

# Removes the specified keys.Time Complexity: O(N)
DEL myKey [key ...]
(integer) 1

