## REDIS STACK COMMANDS: extends the core features of Redis OSS like querying across hashes and JSON documents, time series data support, full-text search ..etc

## JSON#

# Sets JSON value at path in key.Time Complexity: O(M+N) where M is the original size and N is the new size
JSON.SET key path value
JSON.SET employee_profile:1 . '{"name":"Alice"}'
OK


# Returns the JSON value at path in key.Time Complexity: O(N) when path is evaluated to a single value where N is the size of the value, O(N) when path is evaluated to multiple values, where N is the size of the key
JSON.GET key [path [path ...]]
JSON.GET employee_profile:1
{ "name": 'Alice' }


# Increments a number inside a JSON document.Time Complexity: O(1) when path is evaluated to a single value, O(N) when path is evaluated to multiple values, where N is the size of the key
JSON.NUMINCRBY key path number

JSON.SET employee_profile:1 .age 30
JSON.NUMINCRBY employee_profile:1 .age 5
35


# Return the keys in the object that's referenced by path. Time Complexity: O(N) when path is evaluated to a single value, where N is the number of keys in the object, O(N) when path is evaluated to multiple values, where N is the size of the key
JSON.OBJKEYS key [path]
JSON.OBJKEYS employee_profile:1
1) "name" 2) "age"


# Report the number of keys in the JSON object at path in key. Time Complexity: O(1) when path is evaluated to a single value, O(N) when path is evaluated to multiple values, where N is the size of the key
JSON.OBJLEN key [path]
JSON.OBJLEN employee_profile:1
(integer) 2


# Append the json values into the array at path after the last element in it. Time Complexity: O(1) for each value added, O(N) for multiple values added where N is the size of the key
JSON.ARRAPPEND key [path] value [value ...]

JSON.SET employee_profile:1 .colors '["red", "green", "blue"]'
JSON.ARRAPPEND employee_profile:1 .colors '"yellow"'
(integer) 4


# Insert the json values into the array at path before the index (shifts to the right). Time Complexity: O(N) when path is evaluated to a single value where N is the size of the array, O(N) when path is evaluated to multiple values, where N is the size of the key
JSON.ARRINSERT key path index value [value ...]
JSON.ARRINSERT employee_profile:1 .colors 2 '"purple"'
(integer) 5


# Searches for the first occurrence of a JSON value in an array. Time Complexity: O(N) when path is evaluated to a single value where N is the size of the array, O(N) when path is evaluated to multiple values, where N is the size of the key
JSON.ARRINDEX key path value [start [stop]]
JSON.ARRINDEX employee_profile:1 .colors '"purple"'
(integer) 2



## Search and Query

# Create an index with the given specification.Time Complexity: O(K) where K is the number of fields in the document, O(N) for keys in the keySpace
FT.CREATE index
  [ON HASH | JSON]
  [PREFIX count prefix [prefix ...]]
  [FILTER {filter}]
  SCHEMA
  field_name [AS alias] TEXT | TAG | NUMERIC | GEO | VECTOR | GEOSHAPE [ SORTABLE [UNF]]
  [NOINDEX]
   ...

FT.CREATE staff:index
    ON JSON
    PREFIX 1 staff:
    SCHEMA
    "$.name" AS name TEXT
    "$.age" AS age NUMERIC
    "$.isSingle"  AS isSingle TAG
    '$["skills"][*]' AS skills TAG SEPARATOR "|"

OK


# Search the index with a query, returning either documents or just ids. Time Complexity: O(N)
FT.SEARCH index query
  [FILTER numeric_field min max [ FILTER numeric_field min max ...]]
  [RETURN count identifier [AS property] [ identifier [AS property] ...]]
  [SORTBY sortby [ ASC | DESC] [WITHCOUNT]]
  [LIMIT offset num]
  [PARAMS nargs name value [ name value ...]]

JSON.SET "staff:1" "$" '{"name":"Bob","age":22,"isSingle":true,"skills":["NodeJS","MongoDB","React"]}'

JSON.SET "staff:2" "$" '{"name":"Alex","age":45,"isSingle":true,"skills":["Python","MySQL","Angular"]}'

FT.SEARCH staff:index
  "(@name:'alex')"
  RETURN 1 $ LIMIT 0 10

FT.SEARCH staff:index
  "((@isSingle:{true}) (@age:[(18 +inf]))"
  RETURN 1 $ LIMIT 0 10

Output: Matching documents data


# Run a search query on an index, and perform aggregate transformations on the results.
FT.AGGREGATE index query
  [LOAD count field [field ...]]
  [ GROUPBY nargs property [property ...] [ REDUCE function nargs arg [arg ...] [AS name] ...
  [ SORTBY nargs [ property ASC | DESC [ property ASC | DESC ...]] [MAX num] [WITHCOUNT]
  [ APPLY expression AS name  ...
  [ LIMIT offset num]
  [FILTER filter]
  [ PARAMS nargs name value [ name value ...]]

FT.AGGREGATE staff:index "(@age:[(18 +inf])"
  GROUPBY 1 @age
  	REDUCE COUNT_DISTINCT 1 @name AS staff_count

    | age | staff_count |
    | ----| ------------|
    | 22  | 1           |
    | 45  | 1           |



# Return information and statistics on the index.Time Complexity: O(1)
FT.INFO index
FT.INFO staff:index
Output: A list of configuration parameters and stats for the index.



# Dropping existing index.Time Complexity:O(1) or O(N) if documents are deleted, where N is the number of keys in the keyspace
FT.DROPINDEX index [DD]
FT.DROPINDEX staff:index
OK



