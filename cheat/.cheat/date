# Print date in format suitable for affixing to file names
date +"%Y%m%d_%H%M%S"

# Convert Unix timestamp to Date(Linux)
date -d @1440359821

# Convert Unix timestamp to Date(Mac)
date -r 1440359821

# relative
date +%Y-%m-%d -d '-10 day'
date +%Y-%m-%d -d 'yesterday'
date --date='TZ="America/Los_Angeles" 09:00 next Fri'
