### Docker STACK
# stack allow to install Docker compose files on a node that has Docker swarm mode enabled. Allow:
# - Blue/Green deployments
# - Rolling release
# - Secure Secrets
# - Rollbacks
# - Remote Deploy
# - Clustering
#
docker stack deploy -c ./docker-compose.yaml <my-stack-name>
docker stack deploy -c ./docker-compose.yaml <my-stack-name> --with-registry-auth # to avoid warning of repo.
docker service ls  # check after apply
docker service logs <my-app> --raw | jq
docker service scale <my-stack-name>=<number_of_instances>
docker service rollback <my-stack-name>

## Docker Context
export DOCKER_HOST=ssh://root@<machine> # method 1
docker context create <server1-cloud> --docker "host=ssh://root@<machine>"  # method 2 - using context: set docker context to a remote server
docker context ls
docker context use server1-cloud  # change to custom context, every docker command will be executed to the context

