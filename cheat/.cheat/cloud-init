
users:
  - name: demo
    groups: sudo
    shell: /bin/bash
    sudo: ['ALL=(ALL) NOPASSWD:ALL']
    ssh-authorized-keys:
      - ssh-rsa  user@example.com
      - ssh-rsa  user@desktop
    ## generate SSH server’s private keys
    ssh_keys: #  using the rsa_private, rsa_public, dsa_private, dsa_public, ecdsa_private, and ecdsa_public sub-items.
      rsa_private: |
        -----BEGIN RSA PRIVATE KEY-----
        your_rsa_private_key
        -----END RSA PRIVATE KEY-----

      rsa_public: your_rsa_public_key

groups:
  - group1
  - group2: [user1, user2]

# Run commands
runcmd:
  - touch /test.txt
  - [ sed, -i, -e, 's/here/there/g', some_file]
  - echo "modified some_file"
  - [cat, some_file]

# change password for existing user
chpasswd:
  list: |
    user1:password1
    user2:password2
    user3:password3
  expire: False

# write files to disk
write_files:
  - path: /test.txt
    permissions: 0644
    owner: root
    content: |
      Here is a line.
      Another line is here.

# package management
package_update: false
package_upgrade: true
packages:
  - package_1
  - package_2
  - [package_3, version_num]


# Set Up Trusted CA Certificates
ca-certs:
  remove-defaults: true
  trusted:
    - |
      -----BEGIN CERTIFICATE-----
      your_CA_cert
      -----END CERTIFICATE-----

# Configure resolv.conf to Use Specific DNS Servers
manage-resolv-conf: true
resolv_conf:
  nameservers:
    - 'first_nameserver'
    - 'second_nameserver'
  searchdomains:
    - first.domain.com
    - second.domain.com
  domain: domain.com
  options:
    option1: value1
    option2: value2
    option3: value3

# Shutdown or Reboot the Server
power_state:
  timeout: 120
  delay: "+5"
  message: Rebooting in five minutes. Please save your work.
  mode: reboot
