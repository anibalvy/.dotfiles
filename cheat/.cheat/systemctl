systemctl list-units                         # List all loaded/active units
systemctl list-units --all --state=inactive
systemctl list-unit-files
systemctl list-dependencies foo.service      # List the dependencies of a service. when no service name is specified, lists the dependencies of default.target

systemctl get-default               # get default target (aka runlevel)
systemctl list-units --type=target  # List currently loaded targets
systemctl set-default foo.target    # set default target (aka runlevel)
systemctl isolate foo.target        # Change current target
systemctl enable foo.target         # Change default target

systemctl list-units --type=service
systemctl status foo.service                     # Check the status of a service
systemctl is-active application.service
systemctl is-enabled application.service
systemctl is-failed application.service

systemctl edit nginx.service
systemctl edit --full nginx.service
systemctl cat foo.service            # Displaying a Unit File. See info of target, like if can be 'isolate'

systemctl show sshd.service                   # Checking Unit Properties
systemctl show sshd.service -p Conflicts
systemctl show foo.service | grep LimitNOFILE # Grep configuration, like envs

systemctl enable foo.service                     # Enable a service to startup on boot
systemctl disable foo.service                    # Disable a service to startup on boot
systemctl mask nginx.service                     # mark a unit as completely unstartable, automatically or manually, by linking it to /dev/null.
systemctl unmask nginx.service

systemctl start foo.service                      # Start a service
systemctl restart foo.service                    # Restart a service
systemctl stop foo.service                       # Stop a service
systemctl reload foo.service                     # Reload a service's configuration
systemctl reload-or-restart application.service

systemctl reset-failed foo.service # reset failed count

systemctl daemon-reload  #  reload the systemd process

