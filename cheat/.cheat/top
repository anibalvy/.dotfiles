top -i <interval> # Update every <interval> samples

top -s <delay> # Set the delay between updates to <delay> seconds

top -a # Set event counting to accumulative mode

top -d # Set event counting to delta mode

top -e # Set event counting to absolute mode

top -F # Do not calculate statistics on shared libraries, also known as frameworks

top -f # Calculate statistics on shared libraries, also known as frameworks (default)

top -h # Print command line usage information and exit

top -o <key> # Order the display by sorting on <key> in descending order

# the top command uses both of the values found in the /proc/uptime file to calculate the CPU’s idle time percentage.
