

# Install istio with its CNI component:
# *** Note: Istio CNI is required to mirror the network ***
cat <<EOF > istio-cni.yaml
apiVersion: install.istio.io/v1alpha1
kind: IstioOperator
spec:
  components:
    cni:
      enabled: true
EOF

istioctl install -f istio-cni.yaml -y


kubectl label namespace default istio-injection=enabled  # Enable istio Sidecar in your namespace (I’ll use the default namespace):


istioctl analyze   # Check if Istio is operating correctly:
