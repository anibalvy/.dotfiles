

# fix when not allow to enable
sudo rmmod btusb
sudo rmmod btintel
sudo modprobe btintel
sudo modprobe btusb

# also check
rfkill list

# install bluetooth tools to manage Bluetooth devices and connections
apt install bluez

# chef Bluetooth service is up and running
systemctl status bluetooth

# scan for available Bluetooth devices within range:
bluetoothctl scan on

# Find information about all available Bluetooth adapters:
btmgmt info

# List all connected (paired) BT devices:
hcitool con
 bluetoothctl devices
# Find out the Bluetooth version (HCI/LMP) of the remote device by its MAC address
hcitool info AA:2B:21:31:23:BE
# Chech adapter version
hciconfig -a
