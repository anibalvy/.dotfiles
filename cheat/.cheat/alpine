# update the package list
apk update

# install new versions
apk upgrade
apk -i upgrade  # force confirmation
apk upgrade --no-self-upgrade --available --simulate # simulate upgrade

# find all installed packages
apk list --installed

# list installed packages
apk info
apk info -vv | grep 'foo'  # filter out info using the grep command
apk info -vv | sort        # Get verbose outputs and sort it using the sort command

# Find out which package a file belongs to..
apk info --who-owns /etc/passwd

# List contents of the APK PACKAGE
apk -L info pkgName
apk -L info htop

# Check if PACKAGE is installed
apk -e info pkgName

# List packages that the PACKAGE depends on
apk -R info atop

# List all packages depending on PACKAGE
apk info -r pkgNameHere

# Show installed size of PACKAGE
apk info -s pkgName

# Print all information about PACKAGE
apk info -a pkgName

# Repair package or upgrade it without modifying main dependencies
apk fix

# Show repository policy for packages
apk policy bash

# Show statistics about repositories and installations
apk stats

#  search for package
apk search pkgName

# search and display description:
apk search -v -d 'htop'
apk search -v 'php5*' # search package by wildcards

# list all packages available, along with their descriptions
apk search -v

# install a package(s) by name
apk add pkgName
apk -i add nginx # force confirmation
apk add pkgName1 pkgName2

# hold a specific package back and not upgrade it
apk add bash=5.0.0-r0
apk add bash=~5.0      #  hold the version to a major/minor release.
apk add bash>5.0.0-r0  # remove hold

# install a local .apk file package?
apk add --allow-untrusted /path/to/foo.apk
apk add --allow-untrusted pkg1.apk pkg2.apk

# upgrade selected packages only
apk add -u pkgName

# remove or delete a package(s) by name
apk del pkgName
apk del pkgName1 pkgName2

# delete old packages caches
apk cache clean
apk -v cache clean
apk cache -v sync  # One can also clean cache and download missing packages in one step:




