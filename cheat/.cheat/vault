## Signing Keys with CA
# make vault to gen signing key (it can also be imported from existing one)
vault write ssh-client-signer/config/ca generate_signing_key=true
#If you already have a keypair, specify the public and private key parts as part of the payload:
vault write ssh-client-signer/config/ca private_key="..." public_key="..."

# configure vault sssigning role for superadmin access
vault write -f ssh-client-signer/roles/usepradmin-role -<<EOF
{
  allow_user_certificates: true,
  allowed_users: superadmin,
  allowed_extensions: permit-pty,permit-port-forwarding,
  default_extensions: [
    {
      permit-pty:
    }
 ],
  key_type: ca,
  default_user: superadmin,
  ttl: 30m0s
}
EOF

vault write -f ssh-client-signer/roles/superadmin-role - <<EOF
{
  "allow_user_certificates": true,
  "allowed_users": "superadmin",
  "allowed_extensions:": "permit-pty,permit-port-forward",
  "default_extensions": [
    {
      "permit-pty": true
    }
 ],
  "key_type": "ca",
  "default_user": "superadmin",
  "ttl": "30m0s"
}
EOF
