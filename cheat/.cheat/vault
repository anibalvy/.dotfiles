# create policies and respective tokens
vim secret-user-policy.hcl
path "secret/data/*" {  capabilities = ["read"] }

vim secret-admin-policy.hcl
path "secret/data/*" {  capabilities = ["read", "create", "update"] }

# list policies
vault policy list

# command to write policy
vault policy write secret-user-policy secret-user-policy.hcl
vault policy write secret-admin-policy secret-admin-policy.hcl

# read policy
vault policy read secret-user-policy
vault policy read secret-admin-policy

# create token
vault token create -format=json -policy="secret-user-policy"
vault token create -format=json -policy="secret-admin-policy"

# Create custom folder of secrets v2
vault secrets enable -path="my-secrets-folders" kv-v2

### KV V2
# add data
vault kv put -mount=secret creds passcode=my-long-passcode
vault kv put -mount=secret my-secret foo=a bar=b

#The data can also be consumed from a file on disk by prefixing with the "@" symbol. For example:
vault kv put -mount=secret foo @data.json

# using path
vault kv put users/user1/secret1 abc=bfg

# it can be read from stdin using the "-" symbol:
echo "abcd1234" | vault kv put -mount=secret foo bar=-

# list secrets
vault kv list -mount="users" "user1"

# get a secret
vault kv get -mount="users" "user1/secret1"
vault kv get -mount=secret my-secret

# DB Engine
#
vault secrets enable -path=demo-db database   # enable
# configure
vault write demo-db/config/demo-db \
   plugin_name=postgresql-database-plugin \
   allowed_roles="dev-postgres" \
   connection_url="postgresql://{{username}}:{{password}}@postgres-postgresql.postgres.svc.cluster.local:5432/postgres?sslmode=disable" \
   username="postgres" \
   password="secret-pass"
# Create DB Role
vault write demo-db/roles/dev-postgres \
   db_name=demo-db \
   creation_statements="CREATE ROLE \"{{name}}\" WITH LOGIN PASSWORD '{{password}}' VALID UNTIL '{{expiration}}'; \
      GRANT ALL PRIVILEGES ON DATABASE postgres TO \"{{name}}\";" \
   backend=demo-db \
   name=dev-postgres \
   default_ttl="1m" \
   max_ttl="1m"

