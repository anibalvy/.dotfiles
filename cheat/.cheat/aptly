

aptly repo create --distribution=noble -component=main my_repo   # create a repo named my_repo
aptly repo add my_repo my_package.deb                            # add my_package.deb to my_repo repo.
aptly repo show -with-packages my_repo                           # see repo packages
aptly repo list                                                  # see repo list
aptly snapshot create my_repo-snapshot-001 from repo my_repo     # create a snapshot (than can be converted to repo later)
gpg --full-generate-key                                          # create gpg key
gpg --output .aptly/public/my_key.gpg --export <key_id>          # export public key to repo path and to be use to validate packages.
gpg --output my_private.key --export-secret-keys <key_id>        # export private key to be use in others servers use: gpg --import <key_id>
gpg --delete-secret-key <key_id>                                 # delete private key if needed
gpg --delete-key <key_id>                                        # delete public key if needed
sudo curl -fsSL http://<repo_ip>:8080/my_pub_key.gpg -o /etc/apt/trusted.gpg.d/aptly-my_pub_key.gpg  # import key as trusted for use apt


aptly publish snapshot -distribution="noble" -architecture="amd64" \
-component="main" -gpgkey="<id_of_gpg_key>" my_repo-snapshot-001     # publish repo snapshot
aptly serve                                                      # serve repos.
aptly serve -listen=":8080"                                      # serve repos in port


# change snapshot
aptly snapshot drop <snapshot>
aptly publish list
aptly publish drop <distribution_name>
aptly publish snapshot -distribution="noble" -architecture="amd64" \
-component="main" -gpgkey="<id_of_gpg_key>" my_repo-snapshot-001     # publish repo snapshot


