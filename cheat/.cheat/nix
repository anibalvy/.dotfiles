   |_apps
   |     |_ micro.nix   # store application config
   |_ home.nix          # store common home-manager configs


## installation
# Non Standalone:  install nix and integrate on top of nixOS
# Standalone: install just the home-manager like any other program; nix-cli must be installed
# step1: create folder and cd into it
mkdir nix-home-manager && cd nix-home-manager
# step2: create initial configuration files.
nix run home-manager -- init --switch .
# will create home.nix and flake.nix
# cat flake.nix
{
   inputs = {   # inputs are the external repos that the projects depends
     nixpkgs.url = "github:NixOS/nixpkgs/nixos-21.11";
     home-manager = {
        url = "github:nix-community/home-manager";
        inputs.nixpkgs.follows = "nixpkgs";
     };
   };
   outputs = { self, nixpkgs, home-manager }: {
      let
        system = "x86_64-linux";
        pkgs = nixpkgs.legacyPackages.${system};
      in {
      homeConfigurations."nix-home-manager" = home-manager.lib.homeManagerConfiguration {
         inherit pkgs;
         modules = [ ./home.nix ];
      };
   };
};
# Step3: activate the configuration
home-manager switch --flake .#nix-home-manager
   # switch will read and apply the configuration from --flake

home-manager switch --flake .#nix-home-manager -b bkp  # create a backup of the current configuration files before applying the new configuration

home-manager generation list       # list all generations that allows to rollback configuration
home-manager generation switch 1   # rollback to generation 1
nix-collect-garbage --delete-old  # delete old generations
nix-collect-garbage -d            # delete old generations


