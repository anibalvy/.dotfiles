# nix-env
# install package
nix-env -qaP [package-name] # To locate a package in Nix

# To install different Python versions without conflicts, create separate profiles
nix-env --install --profile /nix/var/nix/profiles/python3.11 -iA nixpkgs.python311
nix-env --install --profile /nix/var/nix/profiles/python3.9 -iA nixpkgs.python39


# Verify installation
nix-env -p /nix/var/nix/profiles/python3.11 -q
nix-env -p /nix/var/nix/profiles/python3.9 -q


# Activate a specific version
nix-env --switch-profile /nix/var/nix/profiles/python3.11
python --version  # Confirms the active version


nix-env -u [package-name]  # update a package to the latest available version:

