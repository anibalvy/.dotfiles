mkdir vag-vm; cd vag-vm
vagrant init                            # Initate Vagrant

vagrant plugin install vagrant-libvirt  # install plugin
vagrant plugin list                     # list plugin
vagrant plugin list --local

vagrant box add hashicorp/precise32     # Add a box to vagrant repo

config.vm.box = "hashicorp/precise32"   # Add a box  Vagrant file

config.vm.network "public_network"      # Add vm to public network as host

config.vm.provision :shell, path: "provision.sh" # Add provision script to vagrant file

vagrant up         # Start vm 

vagrant ssh        # Connect to started instance

vagrant halt       # Shutdown vm

vagrant suspend    # Hibernate vm

vagrant destroy    # Set vm to initial state by cleaning all data

vagran reload --provision  # Restart vm with new provision script
